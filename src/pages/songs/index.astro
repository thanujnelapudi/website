---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SongsBrowser from '../../components/SongsBrowser.tsx';
import { getSongs } from '../../utils/sanity';

const allSongs = await getSongs();

const serializedSongs = allSongs.map(song => ({
    id: song._id,
    title: song.title,
    titleTransliterated: song.titleTransliterated,
    slug: song.slug,
    ministry: song.ministry?.name || 'Unknown',
    mood: song.mood || [],
    occasion: song.occasion || [],
    era: song.era || 'modern'
}));
---

<BaseLayout title="All Songs — Telugu Worship">
    <SongsBrowser client:load songs={serializedSongs} />
</BaseLayout>
