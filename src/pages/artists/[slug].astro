---
import { getArtists, getSongs, type SanityArtist, type SanitySong } from '../../utils/sanity';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SongCard from '../../components/SongCard.astro';

export async function getStaticPaths() {
    const artists = await getArtists();
    const songs = await getSongs();
    
    return artists.map(artist => {
        const artistSongs = songs.filter(song => song.artist?._id === artist._id);
        
        return {
            params: { slug: artist.slug },
            props: { artist, songs: artistSongs }
        };
    });
}

interface Props {
    artist: SanityArtist;
    songs: SanitySong[];
}

const { artist, songs } = Astro.props;

const structuredData = {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": artist.name,
    "alternateName": artist.nameTransliterated,
    "description": artist.bio,
    "affiliation": {
        "@type": "Organization",
        "name": artist.ministry?.name || 'Unknown'
    }
};
---

<BaseLayout title={`${artist.name} — Telugu Worship`} structuredData={structuredData}>
    <div class="artist-page">
        <div class="container">
            <!-- HEADER SECTION -->
            <header class="artist-header fade-up">
                <nav class="breadcrumb">
                    <a href="/">Home</a> <span>›</span> <a href="/artists">Artists</a> <span>›</span> <span class="current">{artist.name}</span>
                </nav>

                <div class="header-content">
                    <div class="avatar-large">{artist.name.charAt(0).toUpperCase()}</div>
                    <div class="title-area">
                        <h1 class="main-title">{artist.name}</h1>
                        <p class="trans-title">{artist.nameTransliterated}</p>
                        
                        <div class="metadata-row">
                            {artist.ministry ? (
                                <a href={`/ministries/${artist.ministry.slug}`} class="pill item-ministry link">
                                    {artist.ministry.name}
                                </a>
                            ) : (
                                <span class="pill item-ministry">Unknown Ministry</span>
                            )}
                            <span class="pill count-pill">{songs.length} Songs</span>
                        </div>
                    </div>
                </div>

                {artist.bio && (
                    <div class="bio-section">
                        <p class="bio-text">{artist.bio}</p>
                    </div>
                )}
            </header>
            
            <div class="divider fade-up" style="animation-delay: 0.1s;"></div>
            
            <!-- SONGS SECTION -->
            <section class="songs-section fade-up" style="animation-delay: 0.2s;">
                <h2 class="section-title">Songs</h2>
                <div class="song-list-column">
                    {songs.map(s => (
                        <SongCard 
                            title={s.title}
                            titleTransliterated={s.titleTransliterated}
                            slug={s.slug}
                            ministry={s.ministry?.name || 'Unknown'}
                            mood={s.mood || []}
                            era={s.era}
                        />
                    ))}
                </div>
                {songs.length === 0 && (
                    <div class="empty-state">
                        <p>No songs found for this artist yet.</p>
                    </div>
                )}
            </section>
        </div>
    </div>
</BaseLayout>

<style>
    .artist-page {
        padding: var(--space-3xl) 0;
        background-color: var(--bg);
        min-height: calc(100vh - 64px);
    }

    .container {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 var(--space-xl);
    }

    .breadcrumb {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: var(--space-xl);
        font-family: var(--font-body);
    }
    .breadcrumb a {
        color: var(--text-subtle);
        text-decoration: none;
    }
    .breadcrumb a:hover {
        color: var(--text);
    }
    .breadcrumb span { margin: 0 8px; color: var(--border); }
    .breadcrumb .current { color: var(--text); }

    .header-content {
        display: flex;
        align-items: flex-start;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .avatar-large {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), #443c7a);
        color: #fff;
        font-weight: 600;
        font-size: 4rem;
        font-family: var(--font-display);
        flex-shrink: 0;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    .title-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 120px;
    }

    .main-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3rem);
        color: var(--text);
        margin-bottom: 8px;
        line-height: 1.2;
        font-weight: 700;
    }

    .trans-title {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
        font-family: var(--font-body);
    }

    .metadata-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .pill {
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        font-family: var(--font-body);
    }

    .item-ministry { 
        border-color: var(--accent); 
        color: var(--accent); 
        background: var(--accent-soft);
    }
    
    .item-ministry.link {
        text-decoration: none;
        transition: all 0.2s;
    }
    .item-ministry.link:hover {
        background: var(--accent);
        color: #000;
    }

    .bio-section {
        background: var(--surface-2);
        padding: 1.5rem 2rem;
        border-radius: 12px;
        border: 1px solid var(--border);
        margin-top: 1rem;
    }

    .bio-text {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.6;
        font-family: var(--font-body);
    }

    .divider {
        height: 1px;
        background: var(--border);
        margin: 3rem 0;
    }

    .songs-section {
        margin-bottom: 4rem;
    }

    .section-title {
        font-family: var(--font-display);
        font-size: 1.8rem;
        color: var(--text);
        margin-bottom: 1.5rem;
    }

    .song-list-column {
        display: flex;
        flex-direction: column;
    }

    .empty-state {
        padding: 4rem 1rem;
        text-align: center;
        background: var(--surface);
        border: 1px dashed var(--border);
        border-radius: 12px;
        color: var(--text-muted);
        font-family: var(--font-body);
    }

    @media (max-width: 768px) {
        .header-content {
            flex-direction: column;
            align-items: center;
            text-align: center;
            gap: 1.5rem;
        }
        .metadata-row {
            justify-content: center;
        }
    }
</style>
