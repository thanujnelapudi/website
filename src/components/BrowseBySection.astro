---
const occasions = [
    { 
        label: "Sunday Worship", 
        slug: "sunday-worship", 
        color: "#2563eb",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>`
    },
    { 
        label: "Christmas", 
        slug: "christmas", 
        color: "#dc2626",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
    },
    { 
        label: "Easter", 
        slug: "easter", 
        color: "#16a34a",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 3v18M6 8h12"/></svg>`
    },
    { 
        label: "Wedding", 
        slug: "wedding", 
        color: "#7c3aed",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`
    },
    { 
        label: "Funeral", 
        slug: "funeral", 
        color: "#44403c",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`
    },
    { 
        label: "Children", 
        slug: "children", 
        color: "#d97706",
        icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`
    },
];
---

<section class="home-section">
    <div class="container fade-up">
        <span class="section-label">Explore</span>
        <h2 class="section-heading">Browse Occasions</h2>
        
        <div class="horizontal-scroll">
            {occasions.map(occ => (
                <a href={`/songs?occasion=${occ.slug}`} class="occasion-card" style={`--occ-color: ${occ.color}`}>
                    <div class="icon-wrapper" set:html={occ.icon} />
                    <span class="occasion-name">{occ.label}</span>
                    <span class="small-label">Songs</span>
                </a>
            ))}
        </div>
    </div>
</section>

<style>
    .home-section {
        padding: var(--space-3xl) 0;
    }
    
    /* Horizontal scrolling for cards */
    .horizontal-scroll {
        display: flex;
        gap: 16px;
        overflow-x: auto;
        scrollbar-width: none;
        padding-bottom: 24px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
    }
    
    .horizontal-scroll::-webkit-scrollbar {
        display: none;
    }
    
    .occasion-card {
        flex: 0 0 152px;
        height: 176px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        border-top: 3px solid var(--occ-color);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 20px;
        transition: background 0.2s ease, border-color 0.2s ease;
        scroll-snap-align: start;
    }
    
    .occasion-card:hover {
        background: var(--surface-2);
        border-color: var(--occ-color);
    }
    
    .icon-wrapper {
        color: var(--text-muted);
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s ease;
    }

    .occasion-card:hover .icon-wrapper {
        color: var(--occ-color);
    }
    
    .occasion-name {
        font-family: var(--font-display);
        font-size: 1rem;
        font-weight: 600;
        color: var(--text);
        text-align: center;
        margin-bottom: 4px;
        line-height: 1.2;
    }

    .small-label {
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-family: var(--font-body);
    }
</style>
